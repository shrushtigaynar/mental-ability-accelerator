PORT=4000

# PostgreSQL connection string, e.g.:
# DATABASE_URL=postgres://username:password@localhost:5432/maa_db
DATABASE_URL=

# JWT configuration
JWT_SECRET=super-secure-jwt-secret-change-me
JWT_EXPIRES_IN=7d

# Trial configuration (in days)
TRIAL_DAYS=7

# Bcrypt configuration
BCRYPT_SALT_ROUNDS=10

